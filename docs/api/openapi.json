{
  "openapi": "3.1.0",
  "info": {
    "title": "FeatherFly API",
    "description": "FeatherFly web hosting daemon API — part of the FeatherPanel ecosystem.",
    "contact": {
      "name": "FeatherPanel",
      "url": "https://featherpanel.com",
      "email": "support@featherpanel.com"
    },
    "license": {
      "name": "MIT"
    },
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "paths": {
    "/api/system": {
      "get": {
        "operationId": "get_system",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "architecture",
                    "cpu_count",
                    "kernel_version",
                    "os",
                    "version",
                    "actions"
                  ],
                  "properties": {
                    "actions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ApiAction"
                      }
                    },
                    "architecture": {
                      "type": "string"
                    },
                    "cpu_count": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "kernel_version": {
                      "type": "string"
                    },
                    "os": {
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/api/system/overview": {
      "get": {
        "operationId": "get_system_overview",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "version",
                    "local_time",
                    "container_type",
                    "cpu",
                    "memory",
                    "architecture",
                    "kernel_version"
                  ],
                  "properties": {
                    "architecture": {
                      "type": "string"
                    },
                    "container_type": {
                      "$ref": "#/components/schemas/AppContainerType"
                    },
                    "cpu": {
                      "type": "object",
                      "required": [
                        "name",
                        "brand",
                        "vendor_id",
                        "frequency_mhz",
                        "cpu_count"
                      ],
                      "properties": {
                        "brand": {
                          "type": "string"
                        },
                        "cpu_count": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "frequency_mhz": {
                          "type": "integer",
                          "format": "int64",
                          "minimum": 0
                        },
                        "name": {
                          "type": "string"
                        },
                        "vendor_id": {
                          "type": "string"
                        }
                      }
                    },
                    "kernel_version": {
                      "type": "string"
                    },
                    "local_time": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "memory": {
                      "type": "object",
                      "required": [
                        "total_bytes",
                        "free_bytes",
                        "used_bytes",
                        "used_bytes_process"
                      ],
                      "properties": {
                        "free_bytes": {
                          "type": "integer",
                          "format": "int64",
                          "minimum": 0
                        },
                        "total_bytes": {
                          "type": "integer",
                          "format": "int64",
                          "minimum": 0
                        },
                        "used_bytes": {
                          "type": "integer",
                          "format": "int64",
                          "minimum": 0
                        },
                        "used_bytes_process": {
                          "type": "integer",
                          "format": "int64",
                          "minimum": 0
                        }
                      }
                    },
                    "version": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/api/system/plugins": {
      "get": {
        "operationId": "get_system_plugins",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "enabled",
                    "directory",
                    "hooks",
                    "events",
                    "json_targets",
                    "plugins",
                    "actions"
                  ],
                  "properties": {
                    "actions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ApiAction"
                      }
                    },
                    "directory": {
                      "type": "string"
                    },
                    "enabled": {
                      "type": "boolean"
                    },
                    "events": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "hooks": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "json_targets": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "plugins": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/PluginSummary"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/api/system/update": {
      "get": {
        "operationId": "get_system_update",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "channel",
                    "current_version",
                    "current_commit",
                    "update_available"
                  ],
                  "properties": {
                    "channel": {
                      "$ref": "#/components/schemas/UpdateChannel"
                    },
                    "current_commit": {
                      "type": "string"
                    },
                    "current_version": {
                      "type": "string"
                    },
                    "download_name": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "download_url": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "latest_commit": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "latest_version": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "published_at": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "release_url": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "update_available": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/api/system/upgrade": {
      "post": {
        "operationId": "post_system_upgrade",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url",
                  "sha256",
                  "restart_command"
                ],
                "properties": {
                  "headers": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    },
                    "propertyNames": {
                      "type": "string"
                    }
                  },
                  "restart_command": {
                    "type": "string"
                  },
                  "restart_command_args": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "sha256": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "applied"
                  ],
                  "properties": {
                    "applied": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "error"
                  ],
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "error"
                  ],
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/health": {
      "get": {
        "operationId": "get_health",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "status",
                    "service",
                    "version"
                  ],
                  "properties": {
                    "service": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "ApiAction": {
        "type": "object",
        "required": [
          "id",
          "label"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "step": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "AppContainerType": {
        "type": "string",
        "enum": [
          "official",
          "unknown",
          "none"
        ]
      },
      "PluginSummary": {
        "type": "object",
        "required": [
          "name",
          "version",
          "path",
          "api_version",
          "hooks"
        ],
        "properties": {
          "api_version": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "hooks": {
            "type": "integer",
            "minimum": 0
          },
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "UpdateChannel": {
        "type": "string",
        "enum": [
          "stable",
          "nightly",
          "disabled"
        ]
      }
    },
    "securitySchemes": {
      "bearer_auth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}