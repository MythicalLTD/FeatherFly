{
  "id": "generic-web",
  "name": "Generic Web Server",
  "description": "Nginx serving static files from /home/container (Wings-compatible mount).",
  "author": "FeatherFly",
  "docker_image": "nginx:alpine",
  "startup": "nginx -g 'daemon off;'",
  "entrypoint": ["/bin/bash", "-c"],
  "port": 80,
  "workdir": "/home/container",
  "features": ["web"],
  "file_denylist": [".git", ".backups"],
  "variables": [],
  "config": {
    "startup_done": ["Configuration complete"],
    "stop": { "type": "command", "value": "nginx -s quit" },
    "files": [
      {
        "file": "index.html",
        "parser": "file",
        "create_new": true,
        "replace": [
          {
            "match": "<!-- featherfly -->",
            "replace_with": "<!-- served by FeatherFly -->",
            "update_existing": true
          }
        ]
      }
    ]
  }
}
